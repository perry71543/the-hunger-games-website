{
  "name": "mockingjay-memorial-archive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run validate:data",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "smoke": "node scripts/smoke_test.mjs",
    "check": "npm run validate:data && npm run smoke && npm run lint && npm run build",
    "validate:data": "if command -v python >/dev/null 2>&1; then python scripts/validate_data.py; else /usr/bin/python3 scripts/validate_data.py; fi"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  }
}
